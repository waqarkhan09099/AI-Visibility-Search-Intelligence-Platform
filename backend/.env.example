FLASK_ENV=development
SECRET_KEY=change-me-in-production
DATABASE_URL=sqlite:///instance/app.db
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ─── AI Provider credentials ───────────────────────────────────────────────
# Put your OpenAI API key here. Keys must start with "sk-" and are validated
# on startup and via Settings → AI Configuration in the dashboard.
#
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Default model when running the AI pipeline (must match ai.providers.json)
DEFAULT_AI_MODEL=gpt-4o-mini
DEFAULT_AI_PROVIDER=openai

# ─── Pipeline tuning ───────────────────────────────────────────────────────
PIPELINE_MAX_QUERIES=12
LOG_LEVEL=INFO
