{
  "version": 1,
  "description": "AI provider configuration. API keys are saved securely via Settings in the app.",
  "credential_providers": ["openai", "anthropic", "google"],
  "providers": {
    "openai": {
      "name": "OpenAI",
      "description": "GPT models for query generation, scoring, and recommendations.",
      "env_key": "OPENAI_API_KEY",
      "key_prefixes": ["sk-"],
      "key_placeholder": "sk-...",
      "docs_url": "https://platform.openai.com/api-keys",
      "min_key_length": 20,
      "default_model": "gpt-4o-mini",
      "models": [
        { "id": "gpt-4o-mini", "name": "GPT-4o Mini", "description": "Fast, cost-effective analysis" },
        { "id": "gpt-4o", "name": "GPT-4o", "description": "Highest quality for complex profiles" },
        { "id": "gpt-4.1-mini", "name": "GPT-4.1 Mini", "description": "Balanced speed and reasoning" },
        { "id": "gpt-4.1", "name": "GPT-4.1", "description": "Advanced reasoning" }
      ]
    },
    "anthropic": {
      "name": "Anthropic (Claude)",
      "description": "Claude models for deep reasoning and content strategy.",
      "env_key": "ANTHROPIC_API_KEY",
      "key_prefixes": ["sk-ant-"],
      "key_placeholder": "sk-ant-...",
      "docs_url": "https://console.anthropic.com/settings/keys",
      "min_key_length": 20,
      "default_model": "claude-3-5-haiku-latest",
      "models": [
        { "id": "claude-3-5-haiku-latest", "name": "Claude 3.5 Haiku", "description": "Fast and affordable" },
        { "id": "claude-3-5-sonnet-latest", "name": "Claude 3.5 Sonnet", "description": "Best balance of speed and quality" },
        { "id": "claude-3-opus-latest", "name": "Claude 3 Opus", "description": "Maximum capability" }
      ]
    },
    "google": {
      "name": "Google (Gemini)",
      "description": "Gemini models for scalable AI visibility analysis.",
      "env_key": "GOOGLE_API_KEY",
      "key_prefixes": ["AIza"],
      "key_placeholder": "AIza...",
      "docs_url": "https://aistudio.google.com/apikey",
      "min_key_length": 20,
      "default_model": "gemini-2.0-flash",
      "models": [
        { "id": "gemini-2.0-flash", "name": "Gemini 2.0 Flash", "description": "Fast multimodal analysis" },
        { "id": "gemini-1.5-pro", "name": "Gemini 1.5 Pro", "description": "High-quality long-context reasoning" },
        { "id": "gemini-1.5-flash", "name": "Gemini 1.5 Flash", "description": "Quick responses at lower cost" }
      ]
    },
    "mock": {
      "name": "Mock Provider",
      "description": "Local simulation when no API key is configured.",
      "env_key": null,
      "default_model": "mock-fast",
      "models": [
        { "id": "mock-fast", "name": "Mock Fast", "description": "Deterministic local simulation" },
        { "id": "mock-quality", "name": "Mock Quality", "description": "Richer simulation heuristics" }
      ]
    }
  }
}
